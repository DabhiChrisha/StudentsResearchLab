*.local

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE / Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Docker
docker-compose.override.yml

# Deployment / hosting
.vercel/
.netlify/

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
.pytest_cache/
.coverage
coverage/
*.sqlite3
instance/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.pnpm-store/

# Build output
dist/
dist-ssr/
build/
.vite/
.cache/

# Logs
logs/
*.log
log_*.txt
backend/uvicorn_output.txt
frontend/src/data/output.txt
