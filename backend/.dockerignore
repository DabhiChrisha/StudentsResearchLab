# ── Backend .dockerignore ──

# Dependencies (installed fresh in Docker)
node_modules/

# Environment (injected at runtime)
.env
.env.*
*.local

# Git
.git/
.gitignore
.dockerignore

# IDE / Editor
.vscode/
.idea/
*.sw?

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build artifacts
dist/
build/
coverage/

# Prisma generated client (regenerated inside Docker)
/generated/
/src/generated/

# One-off scripts (not needed in production)
scripts/

# Docs
*.md

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Python
__pycache__/
*.pyc
*.pyo
