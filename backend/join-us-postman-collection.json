{
  "info": {
    "name": "StudentsResearchLab Join Us + Admin Status Flow",
    "description": "Postman collection for testing join-us submission, admin login, and approve/reject join request flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "joinRequestId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Join Us - Submit Application",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/join-us",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "join-us"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ridham Patel\",\n  \"enrollment\": \"22BEIT30133\",\n  \"semester\": \"8\",\n  \"division\": \"J\",\n  \"branch\": \"Information Technology\",\n  \"college\": \"LDRP-ITR\",\n  \"contact\": \"8849155025\",\n  \"email\": \"ridhampatel2k4@yopmail.com\",\n  \"batch\": \"2022-2026\",\n  \"department\": \"CE\",\n  \"after_ug\": \"Yes\",\n  \"cpi\": \"8.2\",\n  \"ieee_member_2026\": \"Yes\",\n  \"ieee_membership\": \"Student Member\",\n  \"research_expertise\": [\"Cyber Forensics\", \"Data Privacy\"],\n  \"published_research\": \"None\",\n  \"ongoing_research\": \"Malware Analysis Lab\",\n  \"source\": \"Website\",\n  \"resume_link\": \"https://example.com/sample-resume.pdf\",\n  \"description\": \"Excited to join the research lab and contribute to cyber forensics work.\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.success && json.data && json.data.id) {",
              "  pm.environment.set('joinRequestId', json.data.id);",
              "  console.log('Stored joinRequestId:', json.data.id);",
              "} else {",
              "  console.warn('Join request response did not contain data.id');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Admin Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"your-admin-password\"\n}"
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json && json.success && json.token) {",
              "  pm.environment.set('adminToken', json.token);",
              "  console.log('Stored adminToken');",
              "} else {",
              "  console.warn('Admin login response did not contain a token');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Admin - Get Join Requests",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/join-requests",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "join-requests"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Admin - Approve Join Request",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/join-requests/{{joinRequestId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "join-requests",
            "{{joinRequestId}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"approved\"\n}"
        }
      },
      "response": []
    },
    {
      "name": "Admin - Reject Join Request",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/join-requests/{{joinRequestId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "join-requests",
            "{{joinRequestId}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"rejected\"\n}"
        }
      },
      "response": []
    }
  ]
}
