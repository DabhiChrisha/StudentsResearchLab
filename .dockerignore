# Root .dockerignore (for frontend Dockerfile build context)

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/
.npm/
.pnpm-store/

# Git
.git
.gitignore

# Backend (has its own Dockerfile)
backend/

# Environment files (passed at build/runtime, not baked into image)
.env
.env.*
frontend/.env
frontend/.env.*
backend/.env
backend/.env.*
*.local

# IDE and editor files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Build artifacts
dist/
build/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/.cache/
coverage/
frontend/coverage/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Misc
*.md
frontend/Researchers_c7.jsx
frontend/Researchers_db.jsx
frontend/StudentsResearchLab/

# Docker build configs
Dockerfile
*Dockerfile*
docker-compose.yml
docker-compose.*.yml
.dockerignore

# Python execution caches
**/__pycache__/
**/*.pyc
**/*.pyo
backend/venv/
backend/.venv/
.pytest_cache/
.coverage
