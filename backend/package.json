{
  "name": "studentsresearchlab-backend-runner",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:pull": "npx prisma db pull",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:reset": "npx prisma migrate reset --force && node prisma/seed.js"
  },
  "description": "This directory contains the Python-based backend service for the Students Research Lab application.",
  "version": "1.0.0",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "nodemon": "^3.0.1"
  },
  "devDependencies": {
    "prisma": "^5.8.0"
  },
  "prisma": {
    "seed": "node prisma/seed-direct.js"
  }
}
