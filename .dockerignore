# ── Root .dockerignore (frontend image build context) ──

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/
.npm/
.pnpm-store/

# Git
.git/
.gitignore
.dockerignore

# Backend (built separately)
backend/

# Environment files (injected at runtime, never baked in)
.env
.env.*
*.local

# IDE / Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code internal
.kilo/

# Build artifacts
dist/
build/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/.cache/
coverage/
frontend/coverage/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Docs and scripts
*.md
*.py
migrate.js
cloudinary-url-map.json

# Docker config files
Dockerfile*
docker-compose*.yml
