# ── StudentsResearchLab Root .gitignore ──

# Environment variables
.env
.env.*
*.local

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE / Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code internal
.kilo/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.pnpm-store/

# Build output
dist/
dist-ssr/
build/
.vite/
.cache/

# Logs
logs/
*.log

# Docker overrides
docker-compose.override.yml

# Deployment
.vercel/
.netlify/

# Python
__pycache__/
*.pyc
*.pyo
venv/
.venv/
.pytest_cache/
.coverage
coverage/

# One-off migration / utility scripts at root
migrate.js
extract_publications.py
cloudinary-url-map.json

# Data files
*.csv
*.xlsx
